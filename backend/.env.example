# ============================================
# ZYNEFINANCE Backend Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
DATABASE_URL=sqlite:///./data/finance.db

# --- Telegram Bot ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_b...n# --- AI Service (BluesMinds) ---
# Get API key from https://api.bluesminds.com
MIMO_API_KEY=your_a...n# --- Google Sheets (Optional) ---
# Service account JSON credentials
GOOGLE_SHEETS_CREDENTIALS={}
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
